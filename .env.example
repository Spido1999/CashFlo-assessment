# ============================================================
# Cashflo AP Policy Rule Engine — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to source control.
# ============================================================

# ----------------------------------------------------------
# LLM Provider (for rule extraction)
# ----------------------------------------------------------

# Groq API key (FREE — recommended, get one at https://console.groq.com)
# Default model: llama-3.3-70b-versatile
GROQ_API_KEY=gsk_...

# OpenAI API key (optional — only if using --provider openai)
OPENAI_API_KEY=sk-...

# Anthropic API key (optional — only if using --provider anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# ----------------------------------------------------------
# Email / SMTP configuration (for sending deviation alerts)
# ----------------------------------------------------------

# SMTP server host (e.g. smtp.gmail.com, smtp.office365.com)
SMTP_HOST=smtp.gmail.com

# SMTP port (587 for TLS/STARTTLS, 465 for SSL)
SMTP_PORT=587

# Use STARTTLS (true) or SSL (false)
SMTP_USE_TLS=true

# SMTP authentication credentials
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password

# Sender address shown in the From field
EMAIL_FROM=ap-automation@cashflo.io

# Optional comma-separated CC addresses for all AP notifications
EMAIL_CC=

# Set to "false" to actually send emails; "true" logs them without sending
EMAIL_DRY_RUN=true
