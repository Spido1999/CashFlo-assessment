    {
      "rule_id": "AP-NOT-028",
      "category": "NOTIFICATION",
      "source_clause": "Section 6.4",
      "description": "Critical deviation triggers immediate email",
      "condition": {
        "operator": "OR",
        "operands": [
          {
            "field": "deviation_pct",
            "op": ">",
            "value": 10
          },
          {
            "field": "compliance_failures",
            "op": "==",
            "value": true
          }
        ]
      },
      "action": "SEND_IMMEDIATE_EMAIL",
      "action_detail": "Immediate email to Finance Controller and Internal Audit team",
      "requires_justification": false,
      "notification": {
        "type": "email",
        "to": [
          "Finance Controller",
          "Internal Audit team"
        ],
        "within_minutes": 0,
        "subject_template": "Critical Deviation Notification",
