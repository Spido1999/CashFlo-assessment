    },
    {
      "rule_id": "AP-NOT-027",
      "category": "NOTIFICATION",
      "source_clause": "Section 6.3",
      "description": "Unresolved deviation triggers escalation email",
      "condition": {
        "operator": "AND",
        "operands": [
          {
            "field": "deviation_detected",
            "op": "==",
            "value": true
          },
          {
            "field": "hours_since_detection",
            "op": ">",
            "value": 48
          }
        ]
      },
      "action": "SEND_EMAIL",
      "action_detail": "Escalation email to next level approver",
      "requires_justification": false,
      "notification": {
        "type": "email",
        "to": [
          "next level approver"
        ],
        "within_minutes": 15,
        "subject_template": "Unresolved Deviation Escalation",
        "include_fields": [
          "invoice_number",
          "vendor_name",
          "po_number",
          "deviation_type",
