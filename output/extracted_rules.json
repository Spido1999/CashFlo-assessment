  "rules": [
    {
      "rule_id": "AP-VAL-001",
      "category": "VALIDATION",
      "source_clause": "Section 1.1",
      "description": "Invoice must contain all mandatory fields",
      "condition": {
        "operator": "AND",
        "operands": [
          {
            "field": "invoice_number",
            "op": "exists"
          },
          {
            "field": "invoice_date",
            "op": "exists"
          },
          {
            "field": "vendor_gstin",
            "op": "exists"
          },
          {
            "field": "po_number",
            "op": "exists"
          },
          {
            "field": "invoice_total",
            "op": "exists"
          }
        ]
      },
      "action": "FLAG",
      "action_detail": "Incomplete",
      "requires_justification": false,
      "priority": 10,
      "confidence_score": 0.95
    },
    {
      "rule_id": "AP-VAL-002",
      "category": "VALIDATION",
      "source_clause": "Section 1.2",
      "description": "Invoice date must not be in the future",
      "condition": {
        "field": "invoice_date",
        "op": "<",
        "value": "current_date"
      },
      "action": "REJECT",
      "action_detail": "Future-Dated Invoice Not Permitted",
      "requires_justification": false,
      "priority": 11,
      "confidence_score": 0.98
    },
    {
      "rule_id": "AP-VAL-004",
      "category": "VALIDATION",
      "source_clause": "Section 1.4",
      "description": "Detect duplicate invoices",
      "condition": {
        "operator": "AND",
        "operands": [
          {
            "field": "invoice_number",
            "op": "exists"
          },
          {
            "field": "vendor_gstin",
            "op": "exists"
          },
          {
            "field": "duplicate_exists",
            "op": "==",
            "value": true
          }
        ]
      },
      "action": "FLAG",
      "action_detail": "Potential Duplicate",
      "requires_justification": false,
      "priority": 12,
      "confidence_score": 0.96
    },
    {
      "rule_id": "AP-PO-005",
      "category": "PO_MATCH",
      "source_clause": "Section 2.1",
      "description": "Invalid PO Reference",
      "condition": {
        "field": "po_number",
        "op": "not_in",
        "value": "active POs"
      },
      "action": "REJECT",
      "action_detail": "Invalid PO Reference",
      "requires_justification": false,
      "priority": 20,
      "confidence_score": 0.95
    },
    {
      "rule_id": "AP-PO-006",
      "category": "PO_MATCH",
      "source_clause": "Section 2.2(a)",
      "description": "Auto-approve within +/- 1% tolerance",
      "condition": {
        "field": "deviation_pct",
        "op": "<=",
        "value": "1"
      },
      "action": "AUTO_APPROVE",
      "requires_justification": false,
      "priority": 21,
      "confidence_score": 0.92
    },
    {
      "rule_id": "AP-PO-007",
      "category": "PO_MATCH",
      "source_clause": "Section 2.2(b)",
      "description": "Route to Department Head for approval (1-10% excess)",
      "condition": {
        "operator": "AND",
        "operands": [
          {
            "field": "deviation_pct",
            "op": ">",
            "value": "1"
          },
          {
            "field": "deviation_pct",
            "op": "<",
            "value": "10"
          }
        ]
      },
      "action": "ROUTE_TO_DEPT_HEAD",
      "requires_justification": false,
      "priority": 22,
      "confidence_score": 0.9
    },
    {
      "rule_id": "AP-PO-008",
      "category": "PO_MATCH",
      "source_clause": "Section 2.2(c)",
      "description": "Escalate to Finance Controller (exceeds 10% tolerance)",
      "condition": {
        "field": "deviation_pct",
        "op": ">=",
        "value": "10"
      },
      "action": "ESCALATE_TO_FINANCE_CONTROLLER",
      "requires_justification": true,
      "priority": 23,
      "confidence_score": 0.95
    },
    {
      "rule_id": "AP-PO-009",
      "category": "PO_MATCH",
      "source_clause": "Section 2.2(d)",
      "description": "Under-invoiced — Verify Partial Delivery",
      "condition": {
        "field": "under_invoiced_pct",
        "op": ">",
        "value": "5"
      },
      "action": "FLAG",
      "action_detail": "Under-Invoiced — Verify Partial Delivery",
      "requires_justification": false,
      "priority": 24,
      "confidence_score": 0.92
    },
    {
      "rule_id": "AP-GRN-010",
      "category": "GRN_MATCH",
      "source_clause": "Section 3.1",
      "description": "GRN must exist for goods-based POs",
      "condition": {
        "field": "grn_exists",
        "op": "is_null",
        "value": true
      },
      "action": "HOLD",
      "action_detail": "Awaiting GRN",
      "requires_justification": false,
      "cross_references": [
        "Section 2.3(b)"
      ],
      "priority": 30,
      "confidence_score": 0.95
    },
    {
      "rule_id": "AP-GRN-011",
      "category": "LINE_ITEM",
      "source_clause": "Section 3.2(a)",
      "description": "Invoice Quantity must be less than or equal to GRN Quantity",
      "condition": {
        "field": "line_items[*].invoice_qty",
        "op": "<=",
        "value": "line_items[*].grn_qty"
      },
      "action": "AUTO_APPROVE",
      "requires_justification": false,
      "priority": 31,
      "confidence_score": 0.98
    },
    {
      "rule_id": "AP-GRN-012",
      "category": "LINE_ITEM",
      "source_clause": "Section 3.2(b)",
      "description": "Invoice Quantity exceeds GRN Quantity",
      "condition": {
        "field": "line_items[*].invoice_qty",
        "op": ">",
        "value": "line_items[*].grn_qty"
      },
      "action": "REJECT",
      "action_detail": "Invoice Qty Exceeds Received Qty",
      "requires_justification": true,
      "notification": {
        "type": "email",
        "to": [
          "AP_CLERK"
        ],
        "within_minutes": 30,
        "subject_template": "Invoice Rejection: {{invoice_number}}",
        "include_fields": [
          "invoice_number",
          "vendor_name",
          "po_number"
        ]
      },
      "cross_references": [
        "Section 2.3(b)"
      ],
      "priority": 32,
      "confidence_score": 0.97
    },
    {
      "rule_id": "AP-GRN-013",
      "category": "GRN_MATCH",
      "source_clause": "Section 3.3",
      "description": "GRN Date must be on or before Invoice Date",
      "condition": {
        "field": "grn_date",
        "op": ">",
        "value": "invoice_date"
      },
      "action": "FLAG",
      "action_detail": "GRN Post-Dated — Verify Receipt Timeline",
      "requires_justification": false,
      "priority": 33,
      "confidence_score": 0.96
    },
    {
      "rule_id": "AP-TAX-014",
      "category": "TAX",
      "source_clause": "Section 4.1",
      "description": "Vendor GSTIN Validation",
      "condition": {
        "field": "vendor_gstin",
        "op": "!=",
        "value": "vendor_master_gstin"
      },
      "action": "REJECT",
      "action_detail": "GSTIN Mismatch — Update Vendor Master or Verify Invoice",
      "requires_justification": false,
      "priority": 40,
      "confidence_score": 0.95
    },
    {
      "rule_id": "AP-TAX-015",
      "category": "TAX",
      "source_clause": "Section 4.2",
      "description": "PAN-GSTIN Cross Check",
      "condition": {
        "field": "vendor_gstin",
        "op": "!=",
        "value": "vendor_pan"
      },
      "action": "COMPLIANCE_HOLD",
      "requires_justification": false,
      "priority": 41,
      "confidence_score": 0.92
    },
    {
      "rule_id": "AP-TAX-016",
      "category": "TAX",
      "source_clause": "Section 4.3(a)",
      "description": "Total Taxable Amount + Total Tax Amount Verification",
      "condition": {
        "field": "taxable_amount",
        "op": "+",
        "value": "tax_amount"
      },
      "action": "FLAG",
      "action_detail": "Tax Calculation Error",
      "requires_justification": false,
      "priority": 42,
      "confidence_score": 0.98
    },
    {
      "rule_id": "AP-TAX-017",
      "category": "TAX",
      "source_clause": "Section 4.3(b)",
      "description": "Intra-state Tax Verification",
      "condition": {
        "operator": "AND",
        "operands": [
          {
            "field": "supply_type",
            "op": "==",
            "value": "intra-state"
          },
          {
            "field": "cgst_amount",
            "op": "==",
            "value": "sgst_amount"
          }
        ]
      },
      "action": "FLAG",
      "action_detail": "Tax Calculation Error",
      "requires_justification": false,
      "priority": 43,
      "confidence_score": 0.95
    },
    {
      "rule_id": "AP-TAX-018",
      "category": "TAX",
      "source_clause": "Section 4.3(c)",
      "description": "Inter-state Tax Verification",
      "condition": {
        "operator": "AND",
        "operands": [
          {
            "field": "supply_type",
            "op": "==",
            "value": "inter-state"
          },
          {
            "field": "igst_amount",
            "op": ">",
            "value": 0
          },
          {
            "field": "cgst_amount",
            "op": "==",
            "value": 0
          },
          {
            "field": "sgst_amount",
            "op": "==",
            "value": 0
          }
        ]
      },
      "action": "FLAG",
      "action_detail": "Tax Calculation Error",
      "requires_justification": false,
      "priority": 44,
      "confidence_score": 0.95
    },
    {
      "rule_id": "AP-TAX-019",
      "category": "TAX",
      "source_clause": "Section 4.4",
      "description": "Place of Supply Verification",
      "condition": {
        "field": "place_of_supply_state",
        "op": "!=",
        "value": "buyer_gstin_state"
      },
      "action": "FLAG",
      "action_detail": "Place of Supply Mismatch",
      "requires_justification": false,
      "priority": 45,
      "confidence_score": 0.92
    },
    {
      "rule_id": "AP-VAL-003",
      "category": "APPROVAL",
      "source_clause": "Section 1.3",
      "description": "Handwritten invoices above INR 50,000 require AP Manager approval",
      "condition": {
        "operator": "AND",
        "operands": [
          {
            "field": "is_handwritten",
            "op": "==",
            "value": true
          },
          {
            "field": "invoice_total",
            "op": ">",
            "value": 50000
          }
        ]
      },
      "action": "ROUTE_TO_AP_MANAGER",
      "requires_justification": false,
      "priority": 50,
      "confidence_score": 0.92
    },
    {
      "rule_id": "AP-APR-020",
      "category": "APPROVAL",
      "source_clause": "Section 5.1",
      "description": "Auto-approve invoices up to INR 1,00,000 if all validations pass",
      "condition": {
        "operator": "AND",
        "operands": [
          {
            "field": "invoice_total",
            "op": "<=",
            "value": "100000"
          },
          {
            "field": "all_validations_passed",
            "op": "==",
            "value": "true"
          }
        ]
      },
      "action": "AUTO_APPROVE",
      "requires_justification": false,
      "cross_references": [
        "Sections 1-4"
      ],
      "priority": 50,
      "confidence_score": 0.95
    },
    {
      "rule_id": "AP-APR-021",
      "category": "APPROVAL",
      "source_clause": "Section 5.2",
      "description": "Require Department Head approval for invoices between INR 1,00,001 and INR 10,00,000",
      "condition": {
        "operator": "AND",
        "operands": [
          {
            "field": "invoice_total",
            "op": ">",
            "value": "100000"
          },
          {
            "field": "invoice_total",
            "op": "<=",
            "value": "1000000"
          }
        ]
      },
      "action": "ROUTE_TO_DEPT_HEAD",
      "requires_justification": false,
      "priority": 51,
      "confidence_score": 0.95
    },
    {
      "rule_id": "AP-APR-022",
      "category": "APPROVAL",
      "source_clause": "Section 5.3",
      "description": "Require Finance Controller approval for invoices between INR 10,00,001 and INR 50,00,000",
      "condition": {
        "operator": "AND",
        "operands": [
          {
            "field": "invoice_total",
            "op": ">",
            "value": "1000000"
          },
          {
            "field": "invoice_total",
            "op": "<=",
            "value": "5000000"
          }
        ]
      },
      "action": "ROUTE_TO_FINANCE_CONTROLLER",
      "requires_justification": false,
      "priority": 52,
      "confidence_score": 0.95
    },
    {
      "rule_id": "AP-APR-023",
      "category": "APPROVAL",
      "source_clause": "Section 5.4",
      "description": "Require CFO approval for invoices above INR 50,00,000",
      "condition": {
        "field": "invoice_total",
        "op": ">",
        "value": "5000000"
      },
      "action": "ROUTE_TO_CFO",
      "requires_justification": false,
      "cross_references": [
        "Section 6"
      ],
      "priority": 53,
      "confidence_score": 0.95
    },
    {
      "rule_id": "AP-APR-024",
      "category": "APPROVAL",
      "source_clause": "Section 5.5",
      "description": "Require Department Head approval for invoices from vendors on the Watch List",
      "condition": {
        "field": "vendor_on_watchlist",
        "op": "==",
        "value": "true"
      },
      "action": "ROUTE_TO_DEPT_HEAD",
      "requires_justification": false,
      "priority": 54,
      "confidence_score": 0.9
    },
    {
      "rule_id": "AP-NOT-025",
      "category": "NOTIFICATION",
      "source_clause": "Section 6.1",
      "description": "Deviation detection triggers email notification",
      "condition": {
        "field": "deviation_detected",
        "op": "==",
        "value": true
      },
      "action": "SEND_EMAIL",
      "action_detail": "Notification of deviation to relevant stakeholder",
      "requires_justification": false,
      "notification": {
        "type": "email",
        "to": [
          "relevant stakeholder"
        ],
        "within_minutes": 15,
