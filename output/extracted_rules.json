    {
      "rule_id": "AP-NOT-026",
      "category": "NOTIFICATION",
      "source_clause": "Section 6.2",
      "description": "Email notification includes specific details",
      "condition": {
        "field": "deviation_detected",
        "op": "==",
        "value": true
      },
      "action": "SEND_EMAIL",
      "action_detail": "Include invoice number, vendor name, PO number, deviation type, deviation details, and recommended action",
      "requires_justification": false,
      "notification": {
        "type": "email",
        "to": [
          "relevant stakeholder"
        ],
        "within_minutes": 15,
        "subject_template": "Deviation Detection Notification",
        "include_fields": [
