      "rule_id": "AP-QR-029",
      "category": "QR_DIGITAL",
      "source_clause": "Section 7.1",
      "description": "QR code required for invoices above INR 10,00,000",
      "condition": {
        "field": "invoice_total",
        "op": ">",
        "value": 1000000
      },
      "action": "HOLD",
      "action_detail": "QR Code Missing — E-Invoice Compliance Required",
