      "rule_id": "AP-QR-030",
      "category": "QR_DIGITAL",
      "source_clause": "Section 7.2",
      "description": "QR code invoice number and vendor GSTIN must match invoice fields",
      "condition": {
        "operator": "AND",
        "operands": [
          {
            "field": "qr_invoice_number",
            "op": "==",
            "value": "invoice_number"
          },
          {
            "field": "qr_vendor_gstin",
            "op": "==",
            "value": "vendor_gstin"
          }
        ]
      },
